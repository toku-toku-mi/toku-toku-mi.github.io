<script>
// ════════════════════════════
//  HELP & NAVIGATION
// ════════════════════════════
function toggleHelp() {
  const howtoScreen = document.getElementById('scr-howto');
  const configScreen = document.getElementById('scr-config');
  
  if (howtoScreen.classList.contains('active')) {
    closeHelp();
  } else {
    howtoScreen.classList.add('active');
    configScreen.classList.remove('active');
  }
}

function closeHelp() {
  const howtoScreen = document.getElementById('scr-howto');
  const configScreen = document.getElementById('scr-config');
  
  howtoScreen.classList.remove('active');
  configScreen.classList.add('active');
}

// ════════════════════════════
//  STATE
// ════════════════════════════
let RACE_COUNT = 4;
let TEAM_COUNT = 14;
let COINS_EACH = 5;
let RACE_SEC = 60;
const CIRC = 270.18;

let RACE_CONFIG = [];
let ROULETTE_DATA = [];

let curRace = 0;
let raceHorses = [];
let raceBets = {};
let raceConfirmed = new Set();
let raceResults = [];
let teamHoldings = [];
let allRaceResults = [];

let rouletteSpinning = false;
let rouletteResult = -1;

let curTeam = -1;
let selHorse = -1;
let teamBets = {};

let timerInt = null;
let timeLeft = RACE_SEC;
let running = false;
let spaceDown = false;

// ════════════════════════════
//  CONFIG
// ════════════════════════════
function startConfig() {
  RACE_COUNT = parseInt(document.getElementById('race-count').value) || 4;
  TEAM_COUNT = parseInt(document.getElementById('team-count').value) || 14;
  COINS_EACH = parseInt(document.getElementById('initial-coins').value) || 5;
  RACE_SEC = parseInt(document.getElementById('race-time').value) || 60;

  RACE_CONFIG = [];
  ROULETTE_DATA = [];
  for (let i = 0; i < RACE_COUNT; i++) {
    RACE_CONFIG.push({ label: `第${i + 1}レース`, count: 5, names: [] });
    ROULETTE_DATA.push(['お題1', 'お題2', 'お題3', 'お題4', 'お題5', 'お題6']);
  }

  buildRaceConfigScreen();
  setScreen('race-config');
}

function buildRaceConfigScreen() {
  const list = document.getElementById('race-config-list');
  list.innerHTML = '';
  RACE_CONFIG.forEach((rc, i) => {
    const section = document.createElement('div');
    section.className = 'config-section';
    section.innerHTML = `
      <div class="config-label">${rc.label}</div>
      <div class="race-config-row">
        <div>出走馬数:</div>
        <input type="number" class="config-input" id="rc-count-${i}" value="${rc.count}" min="1" max="20">
        <div></div>
      </div>
      <div style="margin-top:8px;color:var(--text-dim);font-size:.9rem">ルーレットお題（カンマ区切り、6個推奨）</div>
      <input type="text" class="config-input" id="rc-topics-${i}" value="${rc.topics || ROULETTE_DATA[i].join(',')}" placeholder="お題1,お題2,お題3,...">
    `;
    list.appendChild(section);
  });
}

function finishRaceConfig() {
  RACE_CONFIG.forEach((rc, i) => {
    rc.count = parseInt(document.getElementById(`rc-count-${i}`).value) || 5;
    const topicsStr = document.getElementById(`rc-topics-${i}`).value.trim();
    ROULETTE_DATA[i] = topicsStr ? topicsStr.split(',').map(s => s.trim()) : ['お題1', 'お題2', 'お題3', 'お題4', 'お題5', 'お題6'];
  });

  teamHoldings = Array(TEAM_COUNT).fill(COINS_EACH);
  allRaceResults = [];
  curRace = 0;

  init();
}

function backToConfig() {
  setScreen('config');
}

// ════════════════════════════
//  INIT
// ════════════════════════════
function init() {
  raceHorses = [];
  raceBets = {};
  raceConfirmed.clear();
  raceResults = [];
  rouletteResult = -1;
  buildSetupScreen();
  setScreen('setup');
}

function buildSetupScreen() {
  const cfg = RACE_CONFIG[curRace];
  document.getElementById('setup-race-label').textContent = cfg.label;
  document.getElementById('setup-horse-count-label').textContent = `${cfg.count}人`;

  const grid = document.getElementById('setup-grid');
  grid.innerHTML = '';
  for (let i = 0; i < cfg.count; i++) {
    const defaultName = cfg.names?.[i] || '';
    grid.innerHTML += `
      <div class="horse-input">
        <div class="h-num">${i + 1}</div>
        <input type="text" placeholder="名前" id="hn-${i}" value="${defaultName}">
      </div>`;
  }
}

// ════════════════════════════
//  ROULETTE
// ════════════════════════════
function goRoulette() {
  const cfg = RACE_CONFIG[curRace];
  raceHorses = [];
  for (let i = 0; i < cfg.count; i++) {
    const v = document.getElementById(`hn-${i}`)?.value || `馬${i + 1}`;
    raceHorses.push({ num: i + 1, name: v });
  }
  buildRouletteScreen();
  setScreen('roulette');
}

function buildRouletteScreen() {
  document.getElementById('roulette-race-label').textContent = RACE_CONFIG[curRace].label;
  const items = ROULETTE_DATA[curRace];
  const drum = document.getElementById('roulette-drum');
  drum.innerHTML = '';
  for (let i = 0; i < 20; i++) {
    items.forEach(t => {
      drum.innerHTML += `<div class="rl-item">${t}</div>`;
    });
  }
  const list = document.getElementById('roulette-list');
  list.innerHTML = '';
  items.forEach((t, i) => {
    list.innerHTML += `<div class="rl-list-item" id="rll-${i}">${t}</div>`;
  });
  document.getElementById('roulette-result-area').innerHTML = '';
  document.getElementById('spin-btn').style.display = 'inline-block';
  document.getElementById('next-bet-btn').style.display = 'none';
  document.getElementById('respin-btn').style.display = 'none';
  rouletteResult = -1;
}

function spinRoulette() {
  if (rouletteSpinning) return;
  rouletteSpinning = true;

  const bgm = document.getElementById('roulette-bgm');
  bgm.currentTime = 0;
  bgm.play().catch(err => console.log('Roulette BGM autoplay blocked:', err));

  const items = ROULETTE_DATA[curRace];
  const n = items.length;
  const resultIdx = Math.floor(Math.random() * n);
  rouletteResult = resultIdx;

  const drum = document.getElementById('roulette-drum');
  const itemH = 80;
  const baseRounds = 3;
  const targetPos = (baseRounds * n + resultIdx) * itemH;

  drum.style.transition = 'none';
  drum.style.transform = 'translateY(0)';

  requestAnimationFrame(() => {
    requestAnimationFrame(() => {
      drum.style.transition = `transform 3.5s cubic-bezier(.17,.67,.12,1)`;
      drum.style.transform = `translateY(-${targetPos}px)`;
    });
  });

  setTimeout(() => {
    bgm.pause();
    bgm.currentTime = 0;
    showRouletteResult(resultIdx);
    rouletteSpinning = false;
  }, 3700);
}

function showRouletteResult(idx) {
  const items = ROULETTE_DATA[curRace];
  document.querySelectorAll('.rl-item').forEach((el, i) => {
    el.classList.toggle('selected', i % items.length === idx);
  });
  document.querySelectorAll('.rl-list-item').forEach((el, i) => {
    el.classList.toggle('selected', i === idx);
  });
  const area = document.getElementById('roulette-result-area');
  area.innerHTML = `<div class="roulette-result">🎯 ${items[idx]}</div>`;
  document.getElementById('spin-btn').style.display = 'none';
  document.getElementById('next-bet-btn').style.display = 'inline-block';
  document.getElementById('respin-btn').style.display = 'inline-block';
}

function resetRoulette() {
  buildRouletteScreen();
}

// ════════════════════════════
//  BETTING
// ════════════════════════════
function goBetting() {
  raceBets = {};
  raceConfirmed.clear();
  buildBettingScreen();
  setScreen('bet');
}

function buildBettingScreen() {
  document.getElementById('bet-race-label').textContent = RACE_CONFIG[curRace].label;
  buildOddsBoard();
  const grid = document.getElementById('team-grid');
  grid.innerHTML = '';
  for (let i = 0; i < TEAM_COUNT; i++) {
    const coins = teamHoldings[i];
    const conf = raceConfirmed.has(i);
    const noCoin = coins <= 0;
    const cls = conf ? 'confirmed' : noCoin ? 'no-coins' : '';
    grid.innerHTML += `
      <div class="team-card ${cls}" onclick="selectTeam(${i})" id="tc-${i}">
        <div class="team-name">${i + 1}班</div>
        <div class="team-coins">所持: ${coins}枚</div>
        ${conf ? '<div style="color:var(--green);font-size:.8rem;margin-top:4px">✅ 確定</div>' : ''}
        ${noCoin ? '<div style="color:var(--red);font-size:.8rem;margin-top:4px">コイン不足</div>' : ''}
      </div>`;
  }
  document.getElementById('bet-panel').style.display = 'none';
}

function selectTeam(t) {
  if (raceConfirmed.has(t) || teamHoldings[t] <= 0) return;
  curTeam = t;
  teamBets = raceBets[t] || {};
  document.querySelectorAll('.team-card').forEach(el => el.classList.remove('active'));
  document.getElementById(`tc-${t}`).classList.add('active');
  buildBetPanel();
}

function buildBetPanel() {
  document.getElementById('bet-team-label').textContent = `${curTeam + 1}班`;
  const totalCoins = teamHoldings[curTeam];
  const usedCoins = Object.values(teamBets).reduce((a, b) => a + b, 0);
  const remain = totalCoins - usedCoins;
  document.getElementById('remain-coins').textContent = remain;
  document.getElementById('total-coins').textContent = totalCoins;

  const grid = document.getElementById('bet-horse-grid');
  grid.innerHTML = '';
  raceHorses.forEach((h, i) => {
    const bet = teamBets[i] || 0;
    grid.innerHTML += `
      <div class="bet-horse-btn ${selHorse === i ? 'active' : ''}" onclick="selectHorse(${i})" id="bh-${i}">
        <div style="font-weight:700">${h.name}</div>
        <div style="color:var(--gold);font-size:.85rem;margin-top:4px">${bet}枚</div>
      </div>`;
  });

  if (selHorse >= 0) {
    document.getElementById('coin-sel-area').style.display = 'block';
    document.getElementById('sel-horse-name').textContent = raceHorses[selHorse].name;
    document.getElementById('coin-num').textContent = teamBets[selHorse] || 0;
  } else {
    document.getElementById('coin-sel-area').style.display = 'none';
  }

  document.getElementById('bet-panel').style.display = 'block';
}

function selectHorse(h) {
  selHorse = h;
  buildBetPanel();
  updateSlider();
}

function coinDelta(d) {
  if (selHorse < 0) return;
  const totalCoins = teamHoldings[curTeam];
  const usedCoins = Object.values(teamBets).reduce((a, b) => a + b, 0);
  const remain = totalCoins - usedCoins;
  const cur = teamBets[selHorse] || 0;
  let nv = cur + d;
  if (nv < 0) nv = 0;
  if (d > 0 && remain <= 0) return;
  if (nv > cur && nv - cur > remain) return;
  teamBets[selHorse] = nv;
  updateSlider();
  buildBetPanel();
}

function sliderChange(val) {
  if (selHorse < 0) return;
  const v = parseInt(val);
  const totalCoins = teamHoldings[curTeam];
  const usedCoins = Object.values(teamBets).reduce((a, b) => a + b, 0);
  const curBet = teamBets[selHorse] || 0;
  const remain = totalCoins - usedCoins + curBet;
  if (v > remain) {
    teamBets[selHorse] = remain;
  } else {
    teamBets[selHorse] = v;
  }
  updateSlider();
  buildBetPanel();
}

function updateSlider() {
  const slider = document.getElementById('coin-slider');
  if (!slider) return;
  const totalCoins = teamHoldings[curTeam];
  const usedCoins = Object.values(teamBets).reduce((a, b) => a + b, 0);
  const curBet = teamBets[selHorse] || 0;
  const remain = totalCoins - usedCoins + curBet;
  slider.max = remain;
  slider.value = curBet;
  const percent = remain > 0 ? (curBet / remain) * 100 : 0;
  slider.style.background = `linear-gradient(to right, var(--gold) ${percent}%, var(--border) ${percent}%)`;
}


function confirmTeam() {
  if (curTeam < 0) return;
  raceBets[curTeam] = { ...teamBets };
  raceConfirmed.add(curTeam);
  curTeam = -1;
  selHorse = -1;
  teamBets = {};
  buildBettingScreen();
  buildOddsBoard();
}

function resetTeam() {
  if (curTeam < 0) return;
  teamBets = {};
  selHorse = -1;
  buildBetPanel();
}

function calcOdds() {
  const coins = Array(raceHorses.length).fill(0);
  Object.values(raceBets).forEach(tb => {
    Object.entries(tb).forEach(([hi, c]) => {
      coins[parseInt(hi)] += c;
    });
  });
  const total = coins.reduce((a, b) => a + b, 0);
  const odds = coins.map(c => (c > 0 ? (total / c).toFixed(1) : '---'));
  return { odds, coins, total };
}

function buildOddsBoard() {
  const { odds, coins, total } = calcOdds();
  const el = document.getElementById('odds-list');
  el.innerHTML = '';
  raceHorses.forEach((h, i) => {
    const pct = total > 0 ? Math.round(coins[i] / total * 100) : 0;
    const od = parseFloat(odds[i]);
    const cls = !isNaN(od) ? (od <= 2 ? 'low' : od >= 5 ? 'high' : '') : '';
    el.innerHTML += `
      <div class="odds-row">
        <div><span class="h-num" style="width:26px;height:26px;font-size:.75rem">${h.num}</span></div>
        <div style="font-weight:700">${h.name}</div>
        <div class="odds-val ${cls}">${odds[i]}</div>
        <div class="dim">${coins[i]}枚</div>
        <div><div class="bar-wrap"><div class="bar-fill" style="width:${pct}%"></div></div><div class="dim" style="font-size:.72rem">${pct}%</div></div>
      </div>`;
  });
}

// ════════════════════════════
//  RACE
// ════════════════════════════
function goRace() {
  document.getElementById('race-title').textContent = RACE_CONFIG[curRace].label;
  document.getElementById('race-theme').textContent = `お題: ${ROULETTE_DATA[curRace][rouletteResult]}`;
  timeLeft = RACE_SEC;
  running = false;
  document.getElementById('phase-timer').style.display = 'block';
  document.getElementById('phase-input').style.display = 'none';
  document.getElementById('race-odds-card').style.display = 'none';
  document.getElementById('ctrl-row').style.display = 'flex';
  const display = document.getElementById('timer-display');
  display.textContent = formatTime(RACE_SEC);
  display.classList.remove('warn', 'danger');
  setScreen('race');
}

function formatTime(sec) {
  const m = Math.floor(sec / 60);
  const s = sec % 60;
  return `${m}:${s.toString().padStart(2, '0')}`;
}

function startAllRace() {
  running = true;
  document.getElementById('ctrl-row').style.display = 'none';
  document.getElementById('race-odds-card').style.display = 'block';
  buildRaceOddsBoard();
  timerInt = setInterval(tick, 1000);
  document.addEventListener('keydown', onSpaceDown);
  document.addEventListener('keyup', onSpaceUp);
  const bgm = document.getElementById('race-bgm');
  bgm.currentTime = 0;
  bgm.play().catch(err => console.log('BGM autoplay blocked:', err));
}

function onSpaceDown(e) {
  if (e.code === 'Space' && !spaceDown && running) {
    e.preventDefault();
    spaceDown = true;
    clearInterval(timerInt);
    timerInt = setInterval(tick, 100);
  }
}

function onSpaceUp(e) {
  if (e.code === 'Space') {
    spaceDown = false;
    clearInterval(timerInt);
    if (running) timerInt = setInterval(tick, 1000);
  }
}

function tick() {
  timeLeft--;
  updateTimer();
  if (timeLeft <= 0) {
    clearInterval(timerInt);
    running = false;
    onTimeUp();
  }
}

function updateTimer() {
  const display = document.getElementById('timer-display');
  display.textContent = formatTime(timeLeft);
  
  // 色の変更
  display.classList.remove('warn', 'danger');
  if (timeLeft <= 10) {
    display.classList.add('danger'); // 10秒以下：赤
  } else if (timeLeft <= 30) {
    display.classList.add('warn'); // 30秒以下：黄色
  }
}

function buildRaceOddsBoard() {
  const { odds, coins, total } = calcOdds();
  const el = document.getElementById('race-odds-list');
  el.innerHTML = '';
  raceHorses.forEach((h, i) => {
    const pct = total > 0 ? Math.round(coins[i] / total * 100) : 0;
    const od = parseFloat(odds[i]);
    const cls = !isNaN(od) ? (od <= 2 ? 'low' : od >= 5 ? 'high' : '') : '';
    el.innerHTML += `
      <div class="odds-row">
        <div><span class="h-num" style="width:26px;height:26px;font-size:.75rem">${h.num}</span></div>
        <div style="font-weight:700">${h.name}</div>
        <div class="odds-val ${cls}">${odds[i]}</div>
        <div class="dim">${coins[i]}枚</div>
        <div><div class="bar-wrap"><div class="bar-fill" style="width:${pct}%"></div></div><div class="dim" style="font-size:.72rem">${pct}%</div></div>
      </div>`;
  });
}

function onTimeUp() {
  const bgm = document.getElementById('race-bgm');
  bgm.pause();
  bgm.currentTime = 0;
  document.removeEventListener('keydown', onSpaceDown);
  document.removeEventListener('keyup', onSpaceUp);
  const overlay = document.getElementById('goal-overlay');
  overlay.style.display = 'flex';
  launchConfetti(false);
  setTimeout(() => {
    overlay.style.display = 'none';
    document.getElementById('phase-timer').style.display = 'none';
    document.getElementById('phase-input').style.display = 'block';
    buildScoreInputGrid();
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }, 3000);
}

function buildScoreInputGrid() {
  const grid = document.getElementById('score-grid');
  grid.innerHTML = '';
  raceHorses.forEach((h, i) => {
    grid.innerHTML += `
      <div class="score-card">
        <span class="h-num">${h.num}</span>
        <div style="flex:1;font-weight:700">${h.name}</div>
        <input type="number" id="sc-${i}" value="0" min="0">
        <span class="dim">問正解</span>
      </div>`;
  });
}

// ════════════════════════════
//  RACE RESULT
// ════════════════════════════
function showRaceResult() {
  raceResults = [];
  raceHorses.forEach((h, i) => {
    const correct = parseInt(document.getElementById(`sc-${i}`)?.value) || 0;
    raceResults.push({ horseIdx: i, correct });
  });
  const sorted = [...raceResults].sort((a, b) => b.correct - a.correct);

  allRaceResults.push({
    raceLabel: RACE_CONFIG[curRace].label,
    horses: raceHorses,
    sorted: sorted,
    bets: raceBets
  });

  document.getElementById('rr-race-label').textContent = RACE_CONFIG[curRace].label;
  buildPodium(sorted);
  buildRankTable(sorted);
  calcPayout(sorted);
  buildCoinsBoard();

  if (curRace < RACE_COUNT - 1) {
    document.getElementById('next-race-btn').style.display = 'inline-block';
    document.getElementById('final-btn').style.display = 'none';
  } else {
    document.getElementById('next-race-btn').style.display = 'none';
    document.getElementById('final-btn').style.display = 'inline-block';
  }

  setScreen('rresult');
  launchConfetti(true);
}

function buildPodium(sorted) {
  const podium = document.getElementById('podium');
  podium.innerHTML = '';
  [0, 1, 2].forEach(rank => {
    if (!sorted[rank]) return;
    const h = raceHorses[sorted[rank].horseIdx];
    const medal = rank === 0 ? '🥇' : rank === 1 ? '🥈' : '🥉';
    const cls = rank === 0 ? 'p1' : rank === 1 ? 'p2' : 'p3';
    podium.innerHTML += `
      <div class="podium-place ${cls}">
        <div class="p-rank">${medal}</div>
        <div class="p-name">${h.name}</div>
        <div class="p-score">${sorted[rank].correct}問正解</div>
      </div>`;
  });
}

function buildRankTable(sorted) {
  const tbody = document.getElementById('rank-tbody');
  tbody.innerHTML = '';
  sorted.forEach((s, i) => {
    const h = raceHorses[s.horseIdx];
    const rc = i === 0 ? 'r1' : i === 1 ? 'r2' : i === 2 ? 'r3' : '';
    tbody.innerHTML += `<tr class="${rc}">
      <td>${i + 1}位</td>
      <td><strong>${h.name}</strong></td>
      <td>${s.correct}問</td>
    </tr>`;
  });
}

function calcPayout(sorted) {
  if (sorted.length === 0) return;
  const winIdx = sorted[0].horseIdx;
  const { odds } = calcOdds();
  const winOdds = parseFloat(odds[winIdx]);

  for (let t = 0; t < TEAM_COUNT; t++) {
    const tb = raceBets[t] || {};
    const betOnWin = tb[winIdx] || 0;
    const totalBet = Object.values(tb).reduce((a, b) => a + b, 0);

    if (betOnWin > 0 && !isNaN(winOdds)) {
      const payout = Math.floor(betOnWin * winOdds);
      teamHoldings[t] = teamHoldings[t] - totalBet + payout;
    } else {
      teamHoldings[t] = teamHoldings[t] - totalBet;
    }
  }

  const list = document.getElementById('payout-list');
  list.innerHTML = '';
  for (let t = 0; t < TEAM_COUNT; t++) {
    const tb = raceBets[t] || {};
    const betOnWin = tb[winIdx] || 0;
    const totalBet = Object.values(tb).reduce((a, b) => a + b, 0);
    if (totalBet === 0) continue;

    let msg = '';
    let cls = '';
    if (betOnWin > 0 && !isNaN(winOdds)) {
      const payout = Math.floor(betOnWin * winOdds);
      const net = payout - totalBet;
      msg = `+${net}枚（配当${payout}枚 − 賭け${totalBet}枚）`;
      cls = 'win';
    } else {
      msg = `ハズレ（-${totalBet}枚）`;
      cls = 'lose';
    }

    list.innerHTML += `
      <div class="payout-card">
        <div class="payout-team">${t + 1}班</div>
        <div class="payout-amount ${cls}">${msg}</div>
      </div>`;
  }
}

function buildCoinsBoard() {
  const board = document.getElementById('coins-board');
  board.innerHTML = '<div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(120px,1fr));gap:12px;margin-top:12px">';
  teamHoldings.forEach((c, i) => {
    board.innerHTML += `
      <div style="background:var(--dark);border:1px solid var(--border);border-radius:8px;padding:12px;text-align:center">
        <div style="font-weight:700;margin-bottom:4px">${i + 1}班</div>
        <div style="color:var(--gold);font-size:1.3rem;font-weight:900">${c}枚</div>
      </div>`;
  });
  board.innerHTML += '</div>';
}

function nextRace() {
  curRace++;
  init();
}

function showFinalResult() {
  const teamRanking = teamHoldings.map((coins, i) => ({
    team: i + 1,
    coins: coins,
    gain: coins - COINS_EACH
  })).sort((a, b) => b.coins - a.coins);

  const winner = teamRanking[0];
  document.getElementById('final-champ-team').textContent = `${winner.team}班`;
  document.getElementById('final-champ-coins').textContent = winner.coins;

  const teamTbody = document.getElementById('final-team-tbody');
  teamTbody.innerHTML = '';
  teamRanking.forEach((t, i) => {
    const medal = i === 0 ? '🥇' : i === 1 ? '🥈' : i === 2 ? '🥉' : `${i + 1}位`;
    const rc = i === 0 ? 'r1' : i === 1 ? 'r2' : i === 2 ? 'r3' : '';
    const gainStr = t.gain >= 0 ? `+${t.gain}` : `${t.gain}`;
    const gainColor = t.gain > 0 ? 'color:var(--green-light)' : t.gain < 0 ? 'color:var(--red)' : '';
    teamTbody.innerHTML += `<tr class="${rc}">
      <td>${medal}</td>
      <td><strong>${t.team}班</strong></td>
      <td style="color:var(--gold);font-weight:700">${t.coins}枚</td>
      <td class="dim">${COINS_EACH}枚</td>
      <td style="${gainColor};font-weight:700">${gainStr}</td>
    </tr>`;
  });

  const tbody = document.getElementById('final-tbody');
  tbody.innerHTML = '';
  allRaceResults.forEach(rr => {
    const s = rr.sorted;
    const n = (idx) => s[idx] ? rr.horses[s[idx].horseIdx].name + `(${s[idx].correct}問)` : '---';
    tbody.innerHTML += `<tr>
      <td>${rr.raceLabel}</td>
      <td class="r1"><strong>${n(0)}</strong></td>
      <td>${s[0]?.correct || 0}問</td>
      <td class="r2">${n(1)}</td>
      <td class="r3">${n(2)}</td>
    </tr>`;
  });

  setScreen('final');
  launchConfetti(true);
}

// ════════════════════════════
//  UTILS
// ════════════════════════════
function setScreen(name) {
  const map = { config: 'scr-config', 'race-config': 'scr-race-config', setup: 'scr-setup', roulette: 'scr-roulette', bet: 'scr-bet', race: 'scr-race', rresult: 'scr-rresult', final: 'scr-final' };
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  document.getElementById(map[name]).classList.add('active');
  window.scrollTo({ top: 0, behavior: 'smooth' });
}

function launchConfetti(big = false) {
  const duration = big ? 5000 : 3000;
  const count = big ? 200 : 100;
  for (let i = 0; i < count; i++) {
    setTimeout(() => createConfetti(), Math.random() * duration);
  }
}

function createConfetti() {
  const confetti = document.createElement('div');
  confetti.textContent = ['🎉', '🎊', '✨', '⭐', '🌟'][Math.floor(Math.random() * 5)];
  confetti.style.position = 'fixed';
  confetti.style.left = Math.random() * 100 + 'vw';
  confetti.style.top = '-50px';
  confetti.style.fontSize = (Math.random() * 20 + 20) + 'px';
  confetti.style.zIndex = '9999';
  confetti.style.pointerEvents = 'none';
  document.body.appendChild(confetti);
  const fall = confetti.animate([
    { transform: 'translateY(0) rotate(0deg)', opacity: 1 },
    { transform: `translateY(${window.innerHeight + 100}px) rotate(${Math.random() * 720 - 360}deg)`, opacity: 0 }
  ], {
    duration: Math.random() * 2000 + 3000,
    easing: 'cubic-bezier(0.25, 0.46, 0.45, 0.94)'
  });
  fall.onfinish = () => confetti.remove();
}

function restartAll() {
  location.reload();
}

